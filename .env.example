# =========================================================
# Configuração do bot WhatsApp da EBADV
# Copie este arquivo para .env e edite com os valores reais
# =========================================================

# Endpoint do LIS que recebe as capturas
LIS_CAPTURE_URL=https://ebadv.work/api/whatsapp/capture

# Secret de autenticação (Bearer token) — está nas env vars do Vercel
LIS_CAPTURE_SECRET=COLOQUE_AQUI

# Nome do grupo do WhatsApp que o bot deve escutar
# (qualquer mensagem em outros grupos ou DM é ignorada)
WA_GROUP_NAME=EBADV. Captura

# Caminho onde a sessão Baileys persiste credenciais (não precisa mexer)
WA_AUTH_DIR=./auth_state

# Nível de log do pino (debug | info | warn | error)
LOG_LEVEL=info
