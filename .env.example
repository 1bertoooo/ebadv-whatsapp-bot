# =========================================================
# Configuração do bot WhatsApp da EBADV
# Copie este arquivo para .env e edite com os valores reais
# =========================================================

# Endpoint do LIS que recebe as capturas
LIS_CAPTURE_URL=https://ebadv.work/api/whatsapp/capture

# Secret de autenticação (Bearer token) — está nas env vars do Vercel
LIS_CAPTURE_SECRET=COLOQUE_AQUI

# Nomes dos grupos do WhatsApp que o bot deve escutar.
# Múltiplos grupos: separa com ponto-e-vírgula. O LIS decide o modo de cada
# grupo pelo nome (captura, conversacional Agogê, etc).
# (mensagens em outros grupos ou DM são ignoradas)
WA_GROUP_NAMES=EBADV. Captura;EBadv. Agogê

# OPCIONAL: número do chip do bot, formato internacional sem +, espaço ou traço
# Se setado, o bot usa pareamento por CÓDIGO de 8 dígitos em vez de QR code.
# Útil quando o WhatsApp bloqueia QR (chip recém-ativado, p. ex.)
# Exemplo: WA_PHONE_NUMBER=5543988742822
WA_PHONE_NUMBER=

# Caminho onde a sessão Baileys persiste credenciais (não precisa mexer)
WA_AUTH_DIR=./auth_state

# Nível de log do pino (debug | info | warn | error)
LOG_LEVEL=info
